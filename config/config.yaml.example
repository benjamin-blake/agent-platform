# AWS Configuration
aws:
  region: eu-west-2
  s3_bucket: yahoo-finance-data
  glue_database: trading_formulas_db
  athena_lab_workgroup: lakehouse-trading-lab
  athena_prod_workgroup: lakehouse-trading-production

# PostgreSQL Configuration
postgres:
  host: localhost
  port: 5432
  database: trading
  user: trading
  # Password should be set via environment variable POSTGRES_PASSWORD

# Trading Configuration
trading:
  max_position_size: 1000.0
  latency_threshold: 0.1  # 100ms
  min_signal_threshold: 0.1

# Formula Discovery Configuration
lab:
  pysr_iterations: 100
  min_sharpe_ratio: 0.5
  backtest_period_days: 252  # 1 year

# RAT Ensemble Configuration
live:
  memory_retrieval_top_k: 10
  embedding_dim: 128

# Meta-learner Configuration
meta_learner:
  use_gating_network: true
  learning_rate: 0.001
  hidden_dim: 64

# Sync Configuration
sync:
  interval_hours: 1
  hours_back: 24
  min_sharpe: 0.5
