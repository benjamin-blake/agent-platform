{
  "model": "opus[1m]",
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "1000000"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Skill",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git worktree:*)",
      "Bash(pytest:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(bin/venv-python:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform fmt:*)",
      "mcp__github__create_pull_request",
      "mcp__github__merge_pull_request",
      "mcp__github__subscribe_pr_activity",
      "mcp__github__unsubscribe_pr_activity",
      "mcp__github__pull_request_read",
      "mcp__github__update_pull_request_branch",
      "mcp__github-full"
    ],
    "ask": [],
    "deny": []
  },
  "statusLine": {
    "type": "command",
    "command": "bin/venv-python .claude/statusline.py"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session_start_aws.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session_start_ensure_github_mcp.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session_start_precommit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bin/venv-python .claude/hooks/never_on_main.py"
          },
          {
            "type": "command",
            "command": "bin/venv-python .claude/hooks/edit_scope_guard.py"
          },
          {
            "type": "command",
            "command": "bin/venv-python .claude/hooks/scheduled_agent_log_only.py"
          }
        ]
      }
    ]
  }
}
