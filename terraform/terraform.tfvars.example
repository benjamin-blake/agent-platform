# Core Configuration
aws_region         = "eu-west-2"
aws_profile        = "company-aws-profile"
environment        = "company"  # company|personal
owner_email        = "your.email@company.com"

# S3 Configuration
# Creates buckets: prefix-formulas-discovery, prefix-formulas-staging, prefix-formulas-production
s3_bucket_prefix   = "your-unique-prefix"  # e.g., "bblake-trading" or "acme-ml"

# Glue Configuration
glue_database_name = "formulas_db"

# Cost Monitoring
monthly_budget_usd           = 190.0   # Total budget (~$105-190/month expected)
sagemaker_monthly_budget_usd = 150.0   # SageMaker jobs ($2-5 per run)
athena_monthly_budget_usd    = 30.0    # Athena queries ($5/TB scanned)
anomaly_threshold_usd        = 50.0    # Alert if unexpected cost spike

# Monitoring & Alerting (Optional)
# sns_alert_topic_arn = "arn:aws:sns:eu-west-2:REDACTED-ACCOUNT-ID:trading-alerts"
# slack_webhook_url   = "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# SageMaker Configuration
sagemaker_instance_type       = "ml.t3.xlarge"  # Cost: ~$0.25/hour
sagemaker_max_runtime_seconds = 10800           # 3 hours max (safety limit)

# Athena Configuration
athena_lab_workgroup          = "formula-discovery-lab"
athena_data_scanned_gb_limit  = 100  # Prevent expensive queries
