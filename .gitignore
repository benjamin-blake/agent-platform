# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/.terraform.lock.hcl
terraform/tfplan*
terraform/*.tfplan
terraform/terraform.tfvars
terraform/**/terraform.personal.tfvars
terraform/**/terraform.bootstrap.tfvars
# Sub-module (terraform/personal/) state + provider cache -- local backend embeds the account ID.
terraform/**/.terraform/
terraform/**/*.tfstate
terraform/**/*.tfstate.*
terraform/**/.terraform.lock.hcl
# Exception: terraform/github lock file is committed (version-pins the GitHub provider for supply-chain safety).
!terraform/github/.terraform.lock.hcl
# Exception: terraform/personal lock file is committed (version-pins the third-party kislerdm/neon provider
# for supply-chain safety, T2.16b/CD.34 -- same rationale as terraform/github above).
!terraform/personal/.terraform.lock.hcl
terraform/**/tfplan*
terraform/**/*.tfplan
# Saved terraform plan binary (regenerable; embeds account_id in resource ARNs -- never commit to a public repo).
terraform/**/plan.bin

# Docker
docker/.env

# Environment
.env
*.env

# Cron review temp files (generated by run_cron_review.py --prepare, removed by --merge)
logs/.cron-review-queue.json
logs/.cron-review-responses.json
logs/.preflight-report.json
!.env.example

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Temporary files
/tmp/
*.tmp

# Transient agent working files
# (PLAN-*.md files are now tracked per-branch)

# Lambda build artifacts
lambda-packages/
*.zip

# Config with secrets
config/config.yaml

# Personal scripts
personal_scripts/

# GitHub Copilot CLI telemetry and session exports
# OTel JSONL accumulated data — large, untracked (sync to S3 for long-term storage)
logs/.copilot-otel.jsonl
# Transcript content — all naming schemes, synced to S3 (rec pending)
logs/transcripts/*.md
# Debug call dumps — large text blobs, not for version control
logs/debug/
# Archive directory — large pre-purge snapshots, not for version control
logs/archive/
# the local priority-queue logs are large and S3 is the source of truth, so we can ignore them locally (sync to S3 for long-term storage)
logs/priority-queue/
pip/

# S3-managed log files -- Iceberg is now the authoritative store (Decision 50).
# Local copies remain on disk for existing read tooling; git tracking removed.
# Transient local execution artefacts -- neither outbox nor Athena-derived cache.
logs/.complexity-warnings.json
logs/.execution-state.json
logs/.recommendations-log.jsonl
logs/.execution-plans.jsonl
logs/.session-telemetry.jsonl
logs/.decisions-index.jsonl
logs/.telemetry-*.jsonl
logs/.telemetry-active-session.json

# Outbox (local staging for failed S3 writes -- drained by sync_ops)
# Use /** not / so git traverses the directory and negation patterns can fire
logs/.ops-outbox/**

# Prevent re-creation of the underscore instruction file (Decision 38)
# VS Code loads .github/copilot-instructions.md (hyphen) -- the underscore variant is a ghost.
.github/copilot_instructions.md

# Gemini CLI -- telemetry log is runtime data, not for version control
# settings.json is tracked (project-level config)
.gemini/telemetry.log
.antigravityignore

# Claude Code -- per-machine permission grants and personal overrides.
# .claude/settings.json is tracked (project-level config).
.claude/settings.local.json
.claude/scheduled_tasks.lock
# Transient per-subagent git worktrees created by Agent-tool isolation.
.claude/worktrees/

# History-scrub artifacts (contain live PII/secrets; never commit) -- PLAN-public-migration Step 1
substitutions.txt
logs/runs/
logs/failure-summaries/
